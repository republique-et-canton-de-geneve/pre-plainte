<?xml version="1.0" encoding="UTF-8" ?>
<settings>
    <servers>
        <server>
            <id>clm_server</id>
            <username>${env.CLM_USER}</username>
            <password>${env.***REMOVED***}</password>
        </server>
        <server>
            <id>internal.project.release</id>
            <username>${env.***REMOVED***}</username>
            <password>${env.***REMOVED***}</password>
        </server>
        <server>
            <id>internal.project.snapshot</id>
            <username>${env.***REMOVED***}</username>
            <password>${env.***REMOVED***}</password>
        </server>
        <server>
            <id>internal.lot.release</id>
            <username>${env.***REMOVED***}</username>
            <password>${env.***REMOVED***}</password>
        </server>
        <server>
            <id>internal.lot.snapshot</id>
            <username>${env.***REMOVED***}</username>
            <password>${env.***REMOVED***}</password>
        </server>
        <server>
            <id>projects_Website</id>
            <username>${env.***REMOVED***}</username>
            <password>${env.***REMOVED***}</password>
        </server>
    </servers>

    <mirrors>
        <mirror>
            <id>nexus</id>
            <mirrorOf>*</mirrorOf>
            <url>${nexus.maven.public.url}</url>
        </mirror>
    </mirrors>

    <profiles>
        <profile>
            <id>nexus</id>
            <repositories>
                <repository>
                    <id>central</id>
                    <url>http://central</url>
                    <releases>
                        <enabled>true</enabled>
                    </releases>
                    <snapshots>
                        <enabled>true</enabled>
                    </snapshots>
                </repository>
            </repositories>
            <pluginRepositories>
                <pluginRepository>
                    <id>central</id>
                    <url>http://central</url>
                    <releases>
                        <enabled>true</enabled>
                    </releases>
                    <snapshots>
                        <enabled>true</enabled>
                    </snapshots>
                </pluginRepository>
            </pluginRepositories>
            <properties>
                <maven2Repository_projet>
                    ${env.***REMOVED***}/repositories
                </maven2Repository_projet>
                <maven2Repository_lot>
                    ${env.***REMOVED***}/repositories
                </maven2Repository_lot>
                <siteRepository>
                    ${env.***REMOVED***}/sites/projects_Website
                </siteRepository>
                <projects_Website>
                    ${env.***REMOVED***}/sites/projects_Website
                </projects_Website>
            </properties>
        </profile>
    </profiles>
    <activeProfiles>
        <activeProfile>nexus</activeProfile>
    </activeProfiles>
</settings>
